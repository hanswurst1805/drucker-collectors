[netasset]
# NetAsset-Server URL
api_url = https://<SERVER-URL>

# API-Key (unter Einstellungen → API Keys anlegen)
api_key = sk-na-DEIN_KEY_HIER

# Tags für dieses System (kommagetrennt)
# Beispiel: kunde-a,standort-kiel,production
tags = intern

# Exposure-Level: INTERN | DMZ | EXTERN
exposure_level = INTERN

# Pfad zu osqueryi (leer = automatisch suchen)
# osquery_bin = /usr/bin/osqueryi

# HTTP-Timeout in Sekunden
timeout = 30

# Mindest-Konfidenz für automatische Merges/Konflikte (0.0-1.0 oder 0-100%)
# Wird nur beim Anlegen NEUER Assets gesetzt. Schwache Treffer (1 Soft Key,
# z.B. nur Hostname/IP) werden danach ignoriert statt automatisch gemerged.
# Empfehlung: 0.30-0.40 (30-40%). Leer = Server-Default (0.0 = alles erlauben)
# min_confidence = 0.35
